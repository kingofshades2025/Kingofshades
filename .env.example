# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender must use a domain verified in Resend
EMAIL_FROM="King of Shades <contact@kingofshadesnj.com>"

# Inbox that receives contact & booking notifications
EMAIL_TO=your-business@gmail.com

# Public site URL (canonical — used for Stripe redirects, auth callbacks, and emails)
NEXT_PUBLIC_SITE_URL=https://www.kingofshadesnj.com
# Optional alias; getSiteBaseUrl() prefers NEXT_PUBLIC_SITE_URL
NEXT_PUBLIC_APP_URL=https://kingofshadesnj.com

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Shared secret for Supabase send-email edge function (server-side only)
EMAIL_FUNCTION_SECRET=kos-email-gate-2026

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
